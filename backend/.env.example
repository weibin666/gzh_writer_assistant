# 复制为 backend/.env 并填写

# 大模型（OpenAI 兼容接口）。默认对接 DeepSeek。
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 切换到通义千问（DashScope 兼容模式）示例：
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# 主数据源：sogou(搜狗微信，关键词) / newrank(真实点赞榜单)
CRAWL_SOURCE=sogou
# 抓取的关键词 / 话题（逗号分隔，搜狗源用）
CRAWL_KEYWORDS=AI,人工智能,职场,健康养生,情感
CRAWL_PAGES_PER_KEYWORD=1
# 搜狗被反爬拦截时是否回退到内置示例数据
USE_MOCK_FALLBACK=true

# ① 真实榜单 API（新榜/西瓜等，把 CRAWL_SOURCE 设为 newrank 后生效）
NEWRANK_API_KEY=
NEWRANK_ENDPOINT=
NEWRANK_LIMIT=30

# ② 定时每天自动更新热点（时区 Asia/Shanghai）
SCHEDULE_ENABLED=false
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# AI 配图 / 封面：dashscope(通义万相) / openai(OpenAI兼容) / none
IMAGE_PROVIDER=none
IMAGE_API_KEY=
IMAGE_MODEL=wanx2.1-t2i-turbo
IMAGE_BASE_URL=
IMAGE_SIZE=1024*1024

# ③ 微信公众号草稿（自动存草稿，不自动群发）
WECHAT_APPID=
WECHAT_SECRET=
# 草稿封面图必填：先在素材库上传一张永久图片，把它的 media_id 填这里
WECHAT_DEFAULT_THUMB_MEDIA_ID=
WECHAT_AUTHOR=
